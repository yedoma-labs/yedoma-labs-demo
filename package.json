{
  "name": "yedoma-labs-demo",
  "version": "0.3.0",
  "private": true,
  "description": "Comprehensive demo showcasing Yedoma Labs TypeScript ecosystem for Next.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit"
  },
  "simple-git-hooks": {
    "pre-push": "npm run lint && npm run typecheck && npm run build"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["simple-git-hooks"]
  },
  "packageManager": "pnpm@11.7.0",
  "dependencies": {
    "@yedoma-labs/bylyt-env-guard": "0.3.5",
    "@yedoma-labs/ichchi-state": "0.1.0",
    "@yedoma-labs/sir-forms": "0.2.0",
    "@yedoma-labs/suruk-logger": "0.2.0",
    "@yedoma-labs/suruy-form-actions": "0.1.0",
    "@yedoma-labs/tierde-mail": "0.4.0",
    "@yedoma-labs/turar-config": "0.3.0",
    "@yedoma-labs/tuuru-chrono-tz": "0.3.1",
    "next": "16.2.9",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "postcss": "8.5.15",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "6.0.3"
  }
}
